<!-- ============================================================
     SCRIPTS — GSAP + ScrollTrigger
     ============================================================ -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.7/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.7/ScrollTrigger.min.js"></script>
<script>
    gsap.registerPlugin(ScrollTrigger);

    // ---- Hero entrance animations ----
    const heroTl = gsap.timeline({ defaults: { ease: 'power3.out' } });
    heroTl
        .to('.hero-badge', { opacity: 1, y: 0, duration: 0.6 }, 0.1)
        .fromTo('.hero-badge', { y: 20 }, { y: 0 }, 0.1)
        .to('.hero-title', { opacity: 1, duration: 0.7 }, 0.25)
        .fromTo('.hero-title', { y: 30 }, { y: 0, ease: 'power3.out' }, 0.25)
        .to('.hero-sub', { opacity: 1, duration: 0.6 }, 0.5)
        .fromTo('.hero-sub', { y: 20 }, { y: 0 }, 0.5)
        .to('.hero-cta', { opacity: 1, duration: 0.5 }, 0.65)
        .fromTo('.hero-cta', { y: 15 }, { y: 0 }, 0.65)
        .to('.hero-terminal', { opacity: 1, duration: 0.8 }, 0.8)
        .fromTo('.hero-terminal', { y: 25, scale: 0.98 }, { y: 0, scale: 1 }, 0.8);

    // ---- Scroll-triggered reveals ----
    const revealElements = gsap.utils.toArray('.gs:not(.hero-badge):not(.hero-title):not(.hero-sub):not(.hero-cta):not(.hero-terminal)');
    revealElements.forEach(el => {
        gsap.to(el, {
            scrollTrigger: {
                trigger: el,
                start: 'top 85%',
                toggleActions: 'play none none none',
            },
            opacity: 1,
            y: 0,
            duration: 0.7,
            ease: 'power3.out',
        });
        gsap.set(el, { y: 30 });
    });

    // Staggered reveals for card groups
    document.querySelectorAll('.problem-card, .feature-card, .step').forEach((el, i) => {
        gsap.to(el, {
            scrollTrigger: {
                trigger: el,
                start: 'top 85%',
                toggleActions: 'play none none none',
            },
            opacity: 1,
            y: 0,
            duration: 0.6,
            delay: (i % 3) * 0.12,
            ease: 'power3.out',
        });
    });

    // ---- Nav glassmorphism on scroll ----
    const nav = document.getElementById('nav');
    ScrollTrigger.create({
        start: 50,
        onUpdate: (self) => {
            if (self.scroll() > 50) {
                nav.classList.add('bg-cairn-bg/80', 'backdrop-blur-xl', 'shadow-lg', 'shadow-black/10');
            } else {
                nav.classList.remove('bg-cairn-bg/80', 'backdrop-blur-xl', 'shadow-lg', 'shadow-black/10');
            }
        }
    });

    // ---- Mobile menu toggle ----
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    menuBtn.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
    });

    // ---- Copy command ----
    function copyCmd(btn, cmd) {
        navigator.clipboard.writeText(cmd).then(() => {
            btn.textContent = 'Copied!';
            btn.style.color = '#7c5cfc';
            setTimeout(() => {
                btn.textContent = 'Copy';
                btn.style.color = '';
            }, 2000);
        });
    }
</script>

