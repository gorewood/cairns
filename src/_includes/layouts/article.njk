<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title>{{ title }} — {{ site.title }}</title>
  <script>
    (function() {
      var t = localStorage.getItem('cairns-theme');
      if (t) document.documentElement.setAttribute('data-theme', t);
      else if (window.matchMedia('(prefers-color-scheme: light)').matches)
        document.documentElement.setAttribute('data-theme', 'light');
    })();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/base.css"/>
  <link rel="stylesheet" href="/css/article.css"/>
  <link rel="stylesheet" href="/css/syntax.css"/>
</head>
<body>
  {% include "partials/header.njk" %}

  <div class="progress-bar" id="progress"></div>

  <div class="page-grid">
    <!-- Left Sidebar TOC -->
    <nav class="toc-sidebar" aria-label="Table of contents">
      <div class="toc-sidebar__label">Contents</div>
      <ul class="toc-sidebar__list" id="toc-list"></ul>
    </nav>

    <!-- Main Article Column -->
    <article class="article-content">
      <header class="article-header">
        <div class="article-header__eyebrow">Cairn &middot; {{ date | dateFormat }}</div>
        <h1 class="article-header__title">{{ title }}</h1>
        <p class="article-header__subtitle">{{ subtitle }} &middot; ~{{ duration }} min read &middot; Suggested by {{ submitter }}
          {% if audience %}{% for aud in audience %}<span class="badge badge--audience">{{ aud }}</span>{% endfor %}{% endif %}
        </p>
        {% if lead %}
        <p class="article-header__lead">{{ lead | safe }}</p>
        {% endif %}
      </header>

      {% if prerequisites %}
      <div class="prereq-callout">
        <span class="prereq-callout__label">Before reading this</span>
        <ul>
          {% for slug in prerequisites %}
          {% set prereq = collections.articles | findBySlug(slug) %}
          {% if prereq %}
          <li><a href="{{ prereq.url }}">{{ prereq.data.title }}</a></li>
          {% endif %}
          {% endfor %}
        </ul>
      </div>
      {% endif %}

      <div class="article-body" data-animate data-pagefind-body
           data-pagefind-meta="title:{{ title }}"
           data-pagefind-filter="tag[data-tag]">
        {% for tag in tags %}{% if tag != "articles" %}<span data-tag data-pagefind-filter="tag" hidden>{{ tag }}</span>{% endif %}{% endfor %}
        {{ content | safe }}
      </div>

      {% if trail %}
      {% set trailArticles = collections.trails[trail] %}
      {% if trailArticles %}
      <nav class="trail-nav" aria-label="Trail navigation">
        <div class="trail-nav__header">
          <span class="label label--accent">Trail: {{ trail }}</span>
          <span class="trail-nav__position">Part {{ trailOrder }} of {{ trailArticles | length }}</span>
        </div>
        <div class="trail-nav__links">
          {% set prev = null %}
          {% set next = null %}
          {% for item in trailArticles %}
            {% if item.data.trailOrder == trailOrder - 1 %}{% set prev = item %}{% endif %}
            {% if item.data.trailOrder == trailOrder + 1 %}{% set next = item %}{% endif %}
          {% endfor %}
          {% if prev %}
          <a href="{{ prev.url }}" class="trail-nav__link trail-nav__prev">&larr; {{ prev.data.title }}</a>
          {% else %}
          <span class="trail-nav__link trail-nav__disabled">&larr; Start of trail</span>
          {% endif %}
          {% if next %}
          <a href="{{ next.url }}" class="trail-nav__link trail-nav__next">{{ next.data.title }} &rarr;</a>
          {% else %}
          <span class="trail-nav__link trail-nav__disabled">End of trail &rarr;</span>
          {% endif %}
        </div>
      </nav>
      {% endif %}
      {% endif %}

      {% if related %}
      <div class="related-cairns">
        <span class="label">Related Cairns</span>
        <ul>
          {% for slug in related %}
          {% set rel = collections.articles | findBySlug(slug) %}
          {% if rel %}
          <li><a href="{{ rel.url }}">{{ rel.data.title }}</a> — {{ rel.data.subtitle }}</li>
          {% endif %}
          {% endfor %}
        </ul>
      </div>
      {% endif %}

      <div class="colophon">
        <p>Generated by Cairns &middot; Agent-powered with Claude</p>
        <p><a href="/">&larr; Back to Trailhead</a></p>
      </div>
    </article>
  </div>

  {% include "partials/footer.njk" %}

  <script>
    // Theme toggle
    document.getElementById('theme-toggle').addEventListener('click', function() {
      var html = document.documentElement;
      var current = html.getAttribute('data-theme') || 'dark';
      var next = current === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('cairns-theme', next);
    });

    // Scroll progress bar
    window.addEventListener('scroll', () => {
      const h = document.documentElement.scrollHeight - window.innerHeight;
      if (h > 0) document.getElementById('progress').style.width = (window.scrollY / h) * 100 + '%';
    });

    // Wrap h2-delimited content into <section> elements for TOC and animation
    (function () {
      const body = document.querySelector('.article-body');
      if (!body) return;
      const children = Array.from(body.childNodes);
      let currentSection = null;
      const fragment = document.createDocumentFragment();

      children.forEach(node => {
        if (node.nodeType === 1 && node.tagName === 'H2') {
          currentSection = document.createElement('section');
          currentSection.id = node.id || '';
          fragment.appendChild(currentSection);
          currentSection.appendChild(node);
        } else if (currentSection) {
          currentSection.appendChild(node);
        } else {
          fragment.appendChild(node);
        }
      });
      body.innerHTML = '';
      body.appendChild(fragment);
    })();

    // Auto-generate TOC from sections
    const tocList = document.getElementById('toc-list');
    const sections = document.querySelectorAll('.article-body section[id]');
    sections.forEach(sec => {
      const h = sec.querySelector('h2');
      if (!h) return;
      const li = document.createElement('li');
      const a = document.createElement('a');
      a.href = '#' + sec.id;
      a.textContent = h.textContent;
      a.dataset.section = sec.id;
      li.appendChild(a);
      tocList.appendChild(li);
    });

    // Active TOC link on scroll
    const tocLinks = tocList.querySelectorAll('a');
    const observerToc = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          tocLinks.forEach(l => l.classList.remove('active'));
          const match = tocList.querySelector('a[data-section="' + entry.target.id + '"]');
          if (match) match.classList.add('active');
        }
      });
    }, { rootMargin: '-10% 0px -80% 0px', threshold: 0 });
    sections.forEach(s => observerToc.observe(s));

    // Section reveal animation (respects prefers-reduced-motion)
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const obs = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
      }, { threshold: 0.06 });
      sections.forEach(s => obs.observe(s));
    } else {
      sections.forEach(s => s.classList.add('visible'));
    }
  </script>
  <noscript><style>.article-body[data-animate] section{opacity:1;transform:none;}</style></noscript>
  <!-- Mermaid: client-side diagram rendering with theme toggle support -->
  <script type="module">
    import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs';

    const darkVars = {
      darkMode: true, background: '#14141f',
      primaryColor: '#2a2a4a', primaryTextColor: '#e8e8f0',
      primaryBorderColor: '#7c5cfc', lineColor: '#c0c0cc',
      secondaryColor: '#1e1e30', tertiaryColor: '#0c0c14',
      noteBkgColor: '#2a2a4a', noteTextColor: '#e8e8f0',
      signalTextColor: '#e8e8f0', labelTextColor: '#e8e8f0',
      loopTextColor: '#e8e8f0', messageFontColor: '#e8e8f0',
      actorTextColor: '#e8e8f0', actorBkg: '#2a2a4a', actorBorder: '#7c5cfc',
      activationBorderColor: '#7c5cfc', activationBkgColor: '#1e1e30',
      sequenceNumberColor: '#e8e8f0',
      labelBoxBkgColor: '#2a2a4a', labelBoxBorderColor: '#7c5cfc',
      edgeLabelBackground: '#1e1e30',
      fontFamily: 'Inter, system-ui, sans-serif'
    };

    const lightVars = {
      darkMode: false, background: '#f5f5f0',
      primaryColor: '#ddd8d0', primaryTextColor: '#1a1a2e',
      primaryBorderColor: '#5a3fd4', lineColor: '#555',
      secondaryColor: '#e8e4dc', tertiaryColor: '#f0ece6',
      noteBkgColor: '#ddd8d0', noteTextColor: '#1a1a2e',
      signalTextColor: '#1a1a2e', labelTextColor: '#1a1a2e',
      loopTextColor: '#1a1a2e', messageFontColor: '#1a1a2e',
      actorTextColor: '#1a1a2e', actorBkg: '#ddd8d0', actorBorder: '#5a3fd4',
      activationBorderColor: '#5a3fd4', activationBkgColor: '#e8e4dc',
      sequenceNumberColor: '#1a1a2e',
      labelBoxBkgColor: '#ddd8d0', labelBoxBorderColor: '#5a3fd4',
      edgeLabelBackground: '#f5f5f0',
      fontFamily: 'Inter, system-ui, sans-serif'
    };

    // Store original diagram source for re-rendering on theme toggle
    const mermaidBlocks = document.querySelectorAll('pre.mermaid');
    const originals = Array.from(mermaidBlocks).map(el => el.textContent);

    function getThemeConfig() {
      const isDark = document.documentElement.getAttribute('data-theme') !== 'light';
      return { startOnLoad: false, theme: isDark ? 'dark' : 'default', themeVariables: isDark ? darkVars : lightVars };
    }

    async function renderMermaid() {
      mermaid.initialize(getThemeConfig());
      mermaidBlocks.forEach((el, i) => {
        el.removeAttribute('data-processed');
        el.innerHTML = originals[i];
      });
      await mermaid.run({ nodes: mermaidBlocks });
    }

    // Initial render
    await renderMermaid();

    // Re-render on theme toggle
    document.getElementById('theme-toggle').addEventListener('click', () => {
      // Small delay to let the data-theme attribute update first
      setTimeout(renderMermaid, 50);
    });
  </script>
</body>
</html>
