---
layout: layouts/base.njk
title: Trailhead
pageCss: index.css
---
<div class="layout">

  <!-- Left Sidebar -->
  <aside class="sidebar-left">
    <p class="label">Categories</p>
    <p class="sublabel">Knowledge Trails</p>
    <ul class="cat-list">
      {% set allTags = [] %}
      {% for article in collections.articles %}
        {% for tag in article.data.tags %}
          {% if tag not in allTags %}
            {% set allTags = (allTags.push(tag), allTags) %}
          {% endif %}
        {% endfor %}
      {% endfor %}
      {% for tag in allTags %}
      <li><a href="#">{{ tag | capitalize }}</a></li>
      {% endfor %}
    </ul>
  </aside>

  <!-- Main Content -->
  <main class="main-content">

    {% set featured = collections.articles | first %}
    {% if featured %}
    <!-- Featured Selection -->
    <p class="label label--accent">Latest Cairn</p>
    <div class="hero-card">
      <div class="hero-card__title">{{ featured.data.title }}</div>
      <p class="hero-card__desc">{{ featured.data.subtitle }}</p>
      <div class="hero-card__meta">
        <span>
          <svg class="icon" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          {{ featured.data.date | dateFormat }}
        </span>
        <span>
          <svg class="icon" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          {{ featured.data.duration }} min read
        </span>
        <span>Suggested by: {{ featured.data.submitter }}</span>
      </div>
      <a href="{{ featured.url }}" class="btn-primary">Read Cairn</a>
    </div>
    {% endif %}

    <!-- Search + Tags -->
    <div class="search-bar">
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.35-4.35"/></svg>
      <input type="text" placeholder="Search cairns, topics, contributors..." aria-label="Search cairns"/>
    </div>
    <div class="tag-pills">
      {% for tag in allTags %}
      <button class="tag-pill">{{ tag | capitalize }}</button>
      {% endfor %}
    </div>

    <!-- Article Entries -->
    {% for article in collections.articles %}
    <div class="entry{% if loop.first %} entry--featured{% endif %}">
      <div class="entry__head">
        <div class="entry__body">
          {% if article.data.tags[0] %}
          <span class="entry__cat">{{ article.data.tags[0] | capitalize }}</span>
          {% endif %}
          <h2 class="entry__title"><a href="{{ article.url }}">{{ article.data.title }}</a></h2>
          <p class="entry__desc">{{ article.data.subtitle }}</p>
          <div class="entry__meta">
            <span>{{ article.data.date | dateFormat }}</span>
            <span>{{ article.data.duration }} min</span>
            <span>{{ article.data.submitter }}</span>
          </div>
          {% if loop.first %}
          <a class="entry__reading-link" href="{{ article.url }}">Begin Reading &rarr;</a>
          {% endif %}
        </div>
      </div>
    </div>
    {% endfor %}

  </main>

  <!-- Right Sidebar -->
  <aside class="sidebar-right">
    <p class="label">Contributors</p>
    <ul class="contrib-list">
      {% set contributors = [] %}
      {% for article in collections.articles %}
        {% if article.data.submitter not in contributors %}
          {% set contributors = (contributors.push(article.data.submitter), contributors) %}
        {% endif %}
      {% endfor %}
      {% for name in contributors %}
      <li>{{ name }}</li>
      {% endfor %}
    </ul>

    <p class="label">Metadata</p>
    <dl class="meta-table">
      <dt>Articles</dt>
      <dd>{{ collections.articles.length }}</dd>
      <dt>Status</dt>
      <dd>NOMINAL</dd>
    </dl>
  </aside>

</div>

